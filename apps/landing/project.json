{
  "name": "landing",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/landing/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "astro dev",
        "cwd": "apps/landing"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "astro build",
        "cwd": "apps/landing"
      }
    },
    "preview": {
      "continuous": true,
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "astro preview",
        "cwd": "apps/landing"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "apps/landing"
      }
    }
  }
}
