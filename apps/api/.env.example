# --- Base de datos (Supabase / Postgres) — ADR-001, ADR-010 ---
# Cadena de conexión completa. NUNCA se hardcodea en el código ni se commitea.
# Supabase la entrega en: Project Settings > Database > Connection string (URI).
DATABASE_URL=postgres://user:password@host:5432/postgres

# Supabase exige SSL. En Postgres local de desarrollo, dejar en false.
DATABASE_SSL=true

# Logs de SQL de TypeORM (ruidoso). Útil solo al depurar.
DATABASE_LOGGING=false

# --- Auth / JWT propios (ADR-010) ---
# Secretos independientes para access y refresh. Generar valores largos y
# aleatorios (p. ej. `openssl rand -hex 32`). NO reutilizar el mismo para ambos.
JWT_ACCESS_SECRET=cambiar-por-un-secreto-largo-y-aleatorio
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambiar-por-otro-secreto-largo-y-aleatorio
JWT_REFRESH_EXPIRES_IN=7d

# --- Servidor ---
PORT=3000
